{
  "name": "invoke",
  "version": "1.0.0-local",
  "private": true,
  "description": "API development and testing platform.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @invoke/server --filter @invoke/ui dev",
    "dev:all": "concurrently -n executor,server,ui -c blue,green,magenta \"pnpm executor:dev\" \"pnpm dev:server\" \"pnpm dev:ui\"",
    "dev:server": "pnpm --filter @invoke/server dev",
    "dev:ui": "pnpm --filter @invoke/ui dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:all:turbo": "turbo run dev",
    "e2e": "turbo run build && playwright test",
    "proto:generate": "buf generate",
    "format": "prettier --write .",
    "executor:dev": "cd executor && go run ./cmd/executor",
    "executor:test": "cd executor && go test ./..."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.6.2",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^9.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
