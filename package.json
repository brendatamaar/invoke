{
  "name": "invoke",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Privacy-first API development and testing platform.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @invoke/server --filter @invoke/ui dev",
    "dev:server": "pnpm --filter @invoke/server dev",
    "dev:ui": "pnpm --filter @invoke/ui dev",
    "build": "pnpm -r build",
    "e2e": "pnpm --filter @invoke/core build && playwright test",
    "proto:generate": "buf generate",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "executor:dev": "go run ./executor/cmd/executor",
    "executor:test": "go test ./executor/..."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^9.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
